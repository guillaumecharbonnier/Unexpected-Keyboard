<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<keyboard bottom_row="false" name="Thumb FR (droite)" script="latin">
  <modmap>
    <fn a="switch_forward" b="switch_backward"/>
    <fn a="copy" b="cut"/>
  </modmap>
  <row>
    <key c="0" nw="1" ne="2" sw="3" se="4"/>
    <key c="a" nw="&quot;" ne="à" sw="$" se="v" anticircle="1"/>
    <key c="n" nw="`" ne="^" sw="w" se="\\" anticircle="2"/>
    <key c="i" nw="loc esc" ne="loc tab" sw="x" se="loc €" anticircle="3"/>
    <key role="action" c="switch_emoji" n="cursor_up" s="cursor_down" w="change_method" e="loc switch_clipboard"/>
  </row>
  <row>
    <key c="5" nw="6" ne="7" sw="8" se="9"/>
    <key c="u" nw="b" ne="h" sw="k" se="ê" anticircle="4"/>
    <key c="o" nw="q" ne="j" sw="p" se="g" anticircle="5"/>
    <key c="r" nw="ç" ne="c" sw="d" se="m" anticircle="6"/>
    <key role="action" c="voice_typing" w="copy" n="switch_forward" e="paste" s="selectAll" ne="config"/>
  </row>
  <row>
    <key c="=" nw="+" ne="-" sw="*" se="/"/>
    <key c="t" nw="~" ne="y" sw="l" se="é" anticircle="7"/>
    <key c="e" nw="è" ne="," sw="'" se="." anticircle="8"/>
    <key c="s" nw="f" ne="z" sw=";" se=":" anticircle="9"/>
    <key role="action" c="backspace" s="delete" nw="loc alt" ne="fn" sw="ctrl"/>
  </row>
  <row>
    <key c="!" nw="\?" ne="\#" sw="(" se=")"/>
    <key c="|" nw="[" ne="]" sw="}" se="{"/>
    <key role="space_bar" c="space" w="cursor_left" e="cursor_right" anticircle="0" slider="true"/>
    <key c="\@" nw="&lt;" ne="&gt;" sw="&amp;" se="_"/>
    <key role="action" c="enter" sw="action" nw="shift"/>
  </row>
</keyboard>
