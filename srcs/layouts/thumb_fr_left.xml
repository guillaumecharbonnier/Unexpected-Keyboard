<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<keyboard bottom_row="false" name="Thumb FR (gauche)" script="latin">
  <modmap>
    <fn a="switch_forward" b="switch_backward"/>
    <fn a="copy" b="cut"/>
  </modmap>
  <row>
    <key role="action" c="switch_emoji" n="cursor_up" s="cursor_down" e="change_method" w="switch_forward"/>
    <key c="i" nw="loc accent_trema" ne="loc accent_circonflexe" sw="loc €" se="x" anticircle="3"/>
    <key c="n" nw="&quot;" ne="'" sw="\\" se="w" anticircle="2"/>
    <key c="a" nw="loc accent_grave" ne="esc" sw="v" se="$" anticircle="1"/>
    <key c="0" nw="2" ne="1" sw="4" se="3"/>
  </row>
  <row>
    <key role="action" se="copy" ne="loc switch_clipboard" sw="paste" c="selectAll" nw="config"/>
    <key c="r" nw="c" ne="ç" sw="m" se="d" anticircle="6"/>
    <key c="o" nw="j" ne="q" sw="g" se="p" anticircle="5"/>
    <key c="u" nw="h" ne="b" sw="ê" se="k" anticircle="4"/>
    <key c="5" nw="7" ne="6" sw="9" se="8"/>
  </row>
  <row>
    <key role="action" c="backspace" ne="delete" se="redo" sw="undo" nw="ctrl"/>
    <key c="s" nw="z" ne="f" sw=":" se=";" anticircle="9"/>
    <key c="e" nw="`" ne="è" sw="." se="," anticircle="8"/>
    <key c="t" nw="y" ne="~" sw="é" se="l" anticircle="7"/>
    <key c="=" nw="-" ne="+" sw="/" se="*"/>
  </row>
  <row>
    <key role="action" c="enter" e="voice_typing" ne="shift" n="loc capslock" nw="superscript" w="fn" sw="subscript" se="switch_greekmath"/>
    <key c="?" nw="\#" ne="@" sw="%" se="&amp;"/>
    <key role="space_bar" c="space" s="_" e="cursor_left" w="cursor_right" n="loc tab" anticircle="0" slider="true"/>
    <key c="|" nw="]" ne="[" sw="}" se="{"/>
    <key c="!" nw="&gt;" ne="&lt;" sw=")" se="("/>
  </row>
</keyboard>
