<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<keyboard bottom_row="false" name="Thumb (Français)" script="latin">
  <modmap>
    <fn a="switch_forward" b="switch_backward"/>
    <fn a="copy" b="cut"/>
  </modmap>
  <row>
    <key c="a" nw="&quot;" ne="à" sw="$" se="v" e="%" anticircle="1"/>
    <key c="n" nw="`" sw="/" se="\\" n="loc accent_grave" w="+" e="!" ne="^" s="l" anticircle="2"/>
    <key c="i" n="loc esc" e="loc tab" sw="x" se="loc €" w="\?" s="=" anticircle="3"/>
